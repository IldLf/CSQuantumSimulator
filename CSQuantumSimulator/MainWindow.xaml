<Window x:Class="CSQuantumSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSQuantumSimulator"
        Height="950"
        Width="1700">

	<Grid Margin="20">

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="360"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<StackPanel>

			<TextBlock FontSize="22" FontWeight="Bold" Text="CSQuantumSimulator"/>

			<TextBlock Margin="0 5 0 5" Text="Алгоритм"/>
			<ComboBox Height="30" ItemsSource="{Binding Algorithms}" SelectedItem="{Binding SelectedAlgorithm}"/>

			<TextBlock Margin="0 15 0 5" Text="Количество кубитов"/>
			<TextBox Height="30" Text="{Binding QubitCount, UpdateSourceTrigger=PropertyChanged}"/>

			<TextBlock Margin="0 15 0 5" Text="Целевой кубит"/>
			<TextBox Height="30" Text="{Binding SelectedQubit, UpdateSourceTrigger=PropertyChanged}"/>

			<TextBlock Margin="0 15 0 5" Text="Управляющий кубит"/>
			<TextBox Height="30" Text="{Binding ControlQubit, UpdateSourceTrigger=PropertyChanged}"/>

			<Button Margin="0 15 0 0" Height="35" Content="Выполнить" Command="{Binding ExecuteCommand}"/>
			<Button Margin="0 10 0 0" Height="35" Content="Шаг" Command="{Binding StepCommand}"/>
			<Button Margin="0 10 0 0" Height="35" Content="Измерить" Command="{Binding MeasureCommand}"/>
			<Button Margin="0 10 0 0" Height="35" Content="Сброс" Command="{Binding ResetCommand}"/>

			<TextBlock Margin="0 25 0 10" FontWeight="Bold" Text="Гейты"/>

			<WrapPanel>
				<Button Width="70" Margin="5" Content="H" Command="{Binding AddHCommand}"/>
				<Button Width="70" Margin="5" Content="X" Command="{Binding AddXCommand}"/>
				<Button Width="70" Margin="5" Content="Y" Command="{Binding AddYCommand}"/>
				<Button Width="70" Margin="5" Content="Z" Command="{Binding AddZCommand}"/>
				<Button Width="70" Margin="5" Content="S" Command="{Binding AddSCommand}"/>
				<Button Width="70" Margin="5" Content="T" Command="{Binding AddTCommand}"/>
				<Button Width="70" Margin="5" Content="Rx" Command="{Binding AddRxCommand}"/>
				<Button Width="70" Margin="5" Content="Ry" Command="{Binding AddRyCommand}"/>
				<Button Width="70" Margin="5" Content="Rz" Command="{Binding AddRzCommand}"/>
				<Button Width="70" Margin="5" Content="CNOT" Command="{Binding AddCnotCommand}"/>
				<Button Width="70" Margin="5" Content="CZ" Command="{Binding AddCzCommand}"/>
				<Button Width="70" Margin="5" Content="SWAP" Command="{Binding AddSwapCommand}"/>
			</WrapPanel>

			<StackPanel Orientation="Horizontal" Margin="0 30 0 0">
				<Button Width="120" Height="30" Margin="20 0 40 0" Content="Сохранить" Command="{Binding SaveCommand}"/>
				<Button Width="120" Height="30" Content="Загрузить" Command="{Binding LoadCommand}"/>
			</StackPanel>

		</StackPanel>

		<Grid Grid.Column="1">

			<Grid.RowDefinitions>
				<RowDefinition Height="300"/>
				<RowDefinition Height="70"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<GroupBox Header="Квантовая схема" Margin="10">

				<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Height="250">
					<ItemsControl ItemsSource="{Binding CircuitRows}">

						<ItemsControl.ItemTemplate>
							<DataTemplate>

								<StackPanel Orientation="Horizontal">

									<TextBlock Width="40"
											   VerticalAlignment="Center"
											   FontWeight="Bold"
											   Text="{Binding Qubit}"/>

									<ItemsControl ItemsSource="{Binding Cells}">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<StackPanel Orientation="Horizontal"/>
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>

										<ItemsControl.ItemTemplate>
											<DataTemplate>

												<Border Width="60"
														Height="45"
														Margin="2"
														BorderThickness="1"
														BorderBrush="Gray">

													<Border.Style>
														<Style TargetType="Border">
															<Setter Property="Background" Value="White"/>
															<Style.Triggers>
																<DataTrigger Binding="{Binding IsActive}" Value="True">
																	<Setter Property="Background" Value="LightBlue"/>
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>

													<TextBlock HorizontalAlignment="Center"
															   VerticalAlignment="Center"
															   FontWeight="Bold"
															   Text="{Binding Label}"/>

												</Border>

											</DataTemplate>
										</ItemsControl.ItemTemplate>

									</ItemsControl>

								</StackPanel>

							</DataTemplate>
						</ItemsControl.ItemTemplate>

					</ItemsControl>
				</ScrollViewer>	
			</GroupBox>

			<GroupBox Grid.Row="1" Header="Производительность" Margin="10">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Margin="20 0"
				   FontSize="14"
				   Text="{Binding ExecutionTime, StringFormat=Время: {0:F6} мс}"/>

					<TextBlock Margin="20 0"
				   FontSize="14"
				   Text="{Binding MemoryUsage, StringFormat=Память: {0:F6} КБ}"/>
				</StackPanel>
			</GroupBox>

			<DataGrid Grid.Row="2"
				  Margin="10"
				  ItemsSource="{Binding StateEntries}"
				  AutoGenerateColumns="False"
				  HorizontalScrollBarVisibility="Disabled"
				  CanUserAddRows="False"
				  HeadersVisibility="Column">

				<DataGrid.Columns>

					<DataGridTextColumn Header="Базис" Binding="{Binding Basis}"/>
					<DataGridTextColumn Header="Амплитуда" Binding="{Binding Amplitude}"/>
					<DataGridTextColumn Header="Вероятность (%)" Binding="{Binding Probability}"/>

					<DataGridTemplateColumn Header="Диаграмма" Width="450">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<Grid Width="420" Height="22">
									<Border Background="#ECECEC" CornerRadius="3"/>
									<Border HorizontalAlignment="Left"
										Width="{Binding BarWidth}"
										Background="#4A90E2"
										CornerRadius="3"/>
									<TextBlock HorizontalAlignment="Center"
										   VerticalAlignment="Center"
										   FontSize="11"
										   FontWeight="SemiBold"
										   Text="{Binding Probability, StringFormat={}{0:F2}%}"/>
								</Grid>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

				</DataGrid.Columns>

			</DataGrid>

		</Grid>

	</Grid>

</Window>