<Window x:Class="CSQuantumSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSQuantumSimulator"
        Height="760"
        Width="1400">

	<Grid Margin="20">

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="280"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<StackPanel>

			<ComboBox Height="30"
			          ItemsSource="{Binding Algorithms}"
			          SelectedItem="{Binding SelectedAlgorithm}"/>

			<Button Content="Выполнить" Margin="0 10" Command="{Binding ExecuteCommand}"/>
			<Button Content="Измерить" Margin="0 10" Command="{Binding MeasureCommand}"/>
			<Button Content="Сброс" Margin="0 10" Command="{Binding ResetCommand}"/>

			<TextBlock Margin="0 25 0 10" FontWeight="Bold" Text="Добавить гейт"/>

			<Button Content="H" Margin="0 5" Command="{Binding AddHCommand}"/>
			<Button Content="X" Margin="0 5" Command="{Binding AddXCommand}"/>
			<Button Content="S" Margin="0 5" Command="{Binding AddSCommand}"/>
			<Button Content="T" Margin="0 5" Command="{Binding AddTCommand}"/>
			<Button Content="SWAP" Margin="0 5" Command="{Binding AddSwapCommand}"/>

			<TextBlock Margin="0 25 0 10" FontWeight="Bold" Text="Схема"/>

			<ListBox Height="250" ItemsSource="{Binding CircuitLines}"/>

		</StackPanel>

		<DataGrid Grid.Column="1"
		          ItemsSource="{Binding StateEntries}"
		          AutoGenerateColumns="False">

			<DataGrid.Columns>

				<DataGridTextColumn Header="Базисное состояние" Binding="{Binding Basis}"/>
				<DataGridTextColumn Header="Амплитуда" Binding="{Binding Amplitude}"/>
				<DataGridTextColumn Header="Вероятность (%)" Binding="{Binding Probability}"/>

			</DataGrid.Columns>

		</DataGrid>

	</Grid>
</Window>